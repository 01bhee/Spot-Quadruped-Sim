<mujoco model="spot_terrain_snow">
  <!-- ============================================================
       SAR SCENE V2 — SNOWSTORM (cleaner walking path)
       ============================================================
       Changes from v1:
       - Reduced size of large center snow drifts and frozen barrel
       - Kept ice patches (low, walkable) and edge drifts
       - Friction stays at 0.2 (extreme slippery)
       ============================================================ -->

  <include file="spot.xml"/>

  <option timestep="0.002" iterations="50" solver="Newton" gravity="0 0 -9.81"/>

  <visual>
    <headlight diffuse="0.45 0.5 0.55" ambient="0.4 0.42 0.46" specular="0 0 0"/>
    <rgba haze="0.85 0.88 0.92 1"/>
    <global azimuth="135" elevation="-25" offwidth="1920" offheight="1080"/>
    <quality shadowsize="4096"/>
    <map fogstart="2" fogend="14"/>
  </visual>

  <asset>
    <texture name="tex_sky" type="skybox" builtin="gradient"
             rgb1="0.88 0.9 0.95" rgb2="0.6 0.65 0.72"
             width="512" height="512"/>
    <texture name="tex_floor" type="2d" builtin="checker"
             rgb1="0.92 0.93 0.95" rgb2="0.85 0.87 0.9"
             width="400" height="400"/>
    <texture name="tex_wall" type="2d" builtin="checker"
             rgb1="0.78 0.8 0.85" rgb2="0.72 0.74 0.78"
             width="200" height="200"/>

    <material name="mat_floor" texture="tex_floor" texrepeat="20 20"
              specular="0.4" shininess="0.5" reflectance="0.15"/>
    <material name="mat_wall" texture="tex_wall" texrepeat="3 2"
              specular="0.2" shininess="0.3"/>

    <material name="mat_snow_white"      rgba="0.95 0.96 0.97 1" specular="0.3" shininess="0.4"/>
    <material name="mat_snow_pale"       rgba="0.88 0.9 0.92 1"  specular="0.3" shininess="0.4"/>
    <material name="mat_ice_clear"       rgba="0.75 0.85 0.95 0.9" specular="0.9" shininess="0.95" reflectance="0.4"/>
    <material name="mat_ice_blue"        rgba="0.6 0.78 0.92 0.9"  specular="0.85" shininess="0.9" reflectance="0.35"/>
    <material name="mat_frozen_wood"     rgba="0.4 0.35 0.32 1"  specular="0.3" shininess="0.4"/>
    <material name="mat_frozen_dark"     rgba="0.3 0.32 0.35 1"  specular="0.2"/>
    <material name="mat_metal_frozen"    rgba="0.55 0.6 0.65 1"  specular="0.5" shininess="0.5"/>
    <material name="mat_concrete_frozen" rgba="0.65 0.68 0.72 1" specular="0.2"/>
    <material name="mat_wood_dark"       rgba="0.35 0.28 0.22 1" specular="0.1"/>
    <material name="mat_ice_shard"       rgba="0.75 0.88 0.95 0.95" specular="0.8" shininess="0.9"/>
    <!-- mat_victim and mat_beacon removed — no navigation target in this scene -->
  </asset>

  <worldbody>

    <!-- LIGHTING -->
    <light name="sun" pos="0 4 18" dir="0 -0.3 -1"
           diffuse="0.85 0.9 1.0" specular="0.2 0.22 0.25" castshadow="true"/>
    <light name="ambient_snow" pos="0 -8 12" dir="0 0.4 -1"
           diffuse="0.45 0.48 0.52" specular="0 0 0" castshadow="false"/>

    <!-- FLOOR — friction 0.2 (extreme slippery) -->
    <geom name="floor" type="plane" size="25 25 0.1"
          material="mat_floor" friction="0.2 0.05 0.01"/>

    <!-- ============================================================
         OUTER WALLS
         ============================================================ -->
    <geom name="wall_w_top" type="box" pos="-8 3.5 1.2"  size="0.15 1.5 1.2" material="mat_wall"/>
    <geom name="wall_w_bot" type="box" pos="-8 -3.5 1.2" size="0.15 1.5 1.2" material="mat_wall"/>
    <geom name="wall_e_top" type="box" pos="8 3.0 1.4"   size="0.15 2.0 1.4" material="mat_wall"/>
    <geom name="wall_e_bot" type="box" pos="8 -3.0 1.4"  size="0.15 2.0 1.4" material="mat_wall"/>

    <geom name="wall_n_1" type="box" pos="-5.5 5.0 1.2"  size="2.5 0.15 1.2" material="mat_wall"/>
    <geom name="wall_n_2" type="box" pos="-1.0 5.0 0.9"  size="1.0 0.15 0.9" material="mat_wall"/>
    <geom name="wall_n_3" type="box" pos="2.0 5.0 1.3"   size="1.5 0.15 1.3" material="mat_wall"/>
    <geom name="wall_n_4" type="box" pos="6.0 5.0 1.0"   size="2.0 0.15 1.0" material="mat_wall"/>

    <geom name="wall_s_1" type="box" pos="-5.5 -5.0 1.0"  size="2.5 0.15 1.0" material="mat_wall"/>
    <geom name="wall_s_2" type="box" pos="-1.0 -5.0 1.2"  size="1.0 0.15 1.2" material="mat_wall"/>
    <geom name="wall_s_3" type="box" pos="2.0 -5.0 0.9"   size="1.5 0.15 0.9" material="mat_wall"/>
    <geom name="wall_s_4" type="box" pos="6.0 -5.0 1.3"   size="2.0 0.15 1.3" material="mat_wall"/>

    <!-- ============================================================
         EDGE SNOW DRIFTS (against walls — visual atmosphere)
         ============================================================ -->
    <geom name="drift_n1" type="ellipsoid" pos="-3.5 4.4 0.25"
          size="1.2 0.6 0.25" material="mat_snow_white"/>
    <geom name="drift_n2" type="ellipsoid" pos="0.0 4.5 0.2"
          size="0.9 0.5 0.2" material="mat_snow_pale"/>
    <geom name="drift_n3" type="ellipsoid" pos="4.0 4.4 0.3"
          size="1.3 0.65 0.3" material="mat_snow_white"/>
    <geom name="drift_s1" type="ellipsoid" pos="-3.5 -4.4 0.28"
          size="1.2 0.6 0.28" material="mat_snow_pale"/>
    <geom name="drift_s2" type="ellipsoid" pos="0.5 -4.4 0.25"
          size="1.0 0.55 0.25" material="mat_snow_white"/>
    <geom name="drift_s3" type="ellipsoid" pos="4.0 -4.4 0.3"
          size="1.3 0.65 0.3" material="mat_snow_pale"/>

    <!-- Frozen barrels at edges (atmospheric) -->
    <geom name="edge_barrel_n" type="cylinder" pos="-1.5 3.5 0.3" size="0.28 0.4"
          material="mat_metal_frozen"/>
    <geom name="edge_barrel_s" type="cylinder" pos="2.0 -3.5 0.25" size="0.25 0.35"
          material="mat_metal_frozen" euler="0 80 0"/>

    <!-- ============================================================
         WALKING PATH — flat ice patches and small low debris ONLY
         ============================================================ -->

    <!-- Zone 1 (entry) -->
    <geom name="z1_ice1" type="cylinder" pos="-3.5 0.3 0.005" size="0.7 0.005" material="mat_ice_clear"/>
    <geom name="z1_d1" type="box" pos="-4.5 -0.3 0.05" size="0.1 0.08 0.05" material="mat_frozen_dark"/>
    <geom name="z1_d2" type="cylinder" pos="-3.0 -0.5 0.04" size="0.07 0.04" material="mat_metal_frozen"/>
    <geom name="z1_d3" type="box" pos="-2.5 0.4 0.06" size="0.12 0.1 0.06" material="mat_frozen_wood" euler="0 0 30"/>
    <!-- Small low snow drift (Spot can step over it) -->
    <geom name="z1_drift_low" type="ellipsoid" pos="-3.5 -1.0 0.1" size="0.4 0.3 0.1" material="mat_snow_white"/>

    <!-- Zone 2 (center) — main ice patch + scattered low debris -->
    <geom name="z2_ice_main" type="cylinder" pos="0.0 0.0 0.005" size="1.5 0.005" material="mat_ice_blue"/>
    <geom name="z2_ice2" type="cylinder" pos="1.5 -0.5 0.005" size="0.5 0.005" material="mat_ice_clear"/>
    <geom name="z2_ice3" type="cylinder" pos="-1.2 0.5 0.005" size="0.5 0.005" material="mat_ice_clear"/>

    <!-- Small low debris on path -->
    <geom name="z2_d1" type="box" pos="-1.5 -0.4 0.05" size="0.1 0.08 0.05" material="mat_frozen_dark"/>
    <geom name="z2_d2" type="box" pos="-0.5 0.4 0.06" size="0.12 0.1 0.06" material="mat_frozen_wood" euler="0 0 -20"/>
    <geom name="z2_d3" type="cylinder" pos="0.5 -0.3 0.04" size="0.07 0.04" material="mat_metal_frozen"/>
    <geom name="z2_d4" type="box" pos="1.0 0.4 0.06" size="0.13 0.1 0.06" material="mat_concrete_frozen"/>
    <geom name="z2_d5" type="box" pos="-0.3 -0.6 0.05" size="0.1 0.08 0.05" material="mat_frozen_dark" euler="0 0 40"/>
    <!-- Low concrete chunk -->
    <geom name="z2_chunk" type="box" pos="0.8 0.5 0.08" size="0.18 0.15 0.08"
          material="mat_concrete_frozen" euler="0 0 25"/>

    <!-- Zone 3 (final approach) -->
    <geom name="z3_ice1" type="cylinder" pos="3.5 0.0 0.005" size="0.7 0.005" material="mat_ice_blue"/>
    <geom name="z3_ice2" type="cylinder" pos="5.0 -0.3 0.005" size="0.5 0.005" material="mat_ice_clear"/>
    <geom name="z3_d1" type="box" pos="2.5 -0.4 0.05" size="0.1 0.08 0.05" material="mat_frozen_dark"/>
    <geom name="z3_d2" type="cylinder" pos="3.0 0.5 0.04" size="0.07 0.04" material="mat_metal_frozen"/>
    <geom name="z3_d3" type="box" pos="4.0 -0.5 0.06" size="0.12 0.1 0.06" material="mat_frozen_wood" euler="0 0 30"/>
    <geom name="z3_d4" type="box" pos="4.5 0.3 0.06" size="0.13 0.11 0.06" material="mat_concrete_frozen"/>
    <geom name="z3_d5" type="box" pos="5.2 -0.5 0.05" size="0.1 0.08 0.05" material="mat_frozen_wood"/>


  </worldbody>

</mujoco>